@tailwind base;
@tailwind components;
@tailwind utilities;

/* Definition of the design system. All colors, gradients, fonts, etc should be defined here. 
All colors MUST be HSL.
*/

@layer base {
  :root {
    --background: 222 15% 5%;
    --foreground: 48 100% 95%;

    --card: 222 15% 8%;
    --card-foreground: 48 100% 95%;

    --popover: 222 15% 8%;
    --popover-foreground: 48 100% 95%;

    --primary: 48 100% 67%;
    --primary-foreground: 222 15% 5%;

    --secondary: 222 20% 15%;
    --secondary-foreground: 48 100% 95%;

    --muted: 222 20% 12%;
    --muted-foreground: 48 20% 65%;

    --accent: 222 25% 20%;
    --accent-foreground: 48 100% 85%;

    --destructive: 0 85% 60%;
    --destructive-foreground: 48 100% 95%;

    --border: 222 20% 18%;
    --input: 222 20% 18%;
    --ring: 48 100% 67%;

    /* Brand colors (subdued, premium) */
    --gold: 46 90% 58%;
    --gold-light: 46 90% 68%;
    --gold-dark: 44 85% 45%;
    --gold-glow: 46 90% 74%;

    /* Accents (subdued) */
    --tech-red: 0 65% 46%;
    --tech-blue: 220 50% 42%;
    --tech-cyan: 190 35% 42%;
    --tech-purple: 260 30% 38%;
    --tech-white: 48 100% 98%;

    /* Gradients (calm, low contrast) */
    --gradient-primary: linear-gradient(135deg, hsl(var(--gold)) 0%, hsl(var(--gold-light)) 50%, hsl(var(--gold-glow)) 100%);
    --gradient-hero: radial-gradient(ellipse at 20% 0%, hsl(222 16% 6%) 0%, hsl(222 16% 6%) 50%, hsl(var(--gold) / 0.08) 100%);
    --gradient-card: linear-gradient(145deg, hsl(222 16% 8%) 0%, hsl(222 16% 8%) 100%);
    --gradient-tech: linear-gradient(45deg, hsl(222 16% 8%) 0%, hsl(222 16% 8%) 100%);
    --gradient-hologram: linear-gradient(90deg, hsl(var(--gold)) 0%, hsl(var(--gold-light)) 100%);
    --gradient-radial: radial-gradient(circle at center, hsl(var(--gold) / 0.2) 0%, hsl(var(--gold) / 0.1) 50%, transparent 100%);

    /* Shadows (diffused, non-neon) */
    --shadow-gold: 0 8px 28px hsl(var(--gold) / 0.25), 0 2px 8px hsl(var(--gold) / 0.15);
    --shadow-card: 0 8px 28px hsl(222 25% 3% / 0.6), 0 0 0 1px hsl(var(--gold) / 0.08);
    --shadow-float: 0 16px 40px hsl(var(--gold) / 0.22);
    --shadow-neon: 0 6px 18px hsl(var(--gold) / 0.18);
    --shadow-hologram: 0 10px 28px hsl(var(--gold) / 0.25);
    --shadow-tech-blue: 0 8px 28px hsl(var(--tech-blue) / 0.25), 0 2px 8px hsl(var(--tech-blue) / 0.15);
    --shadow-tech-red: 0 8px 28px hsl(var(--tech-red) / 0.25), 0 2px 8px hsl(var(--tech-red) / 0.15);

    --radius: 0.5rem;

    --sidebar-background: 0 0% 98%;

    --sidebar-foreground: 240 5.3% 26.1%;

    --sidebar-primary: 240 5.9% 10%;

    --sidebar-primary-foreground: 0 0% 98%;

    --sidebar-accent: 240 4.8% 95.9%;

    --sidebar-accent-foreground: 240 5.9% 10%;

    --sidebar-border: 220 13% 91%;

    --sidebar-ring: 217.2 91.2% 59.8%;
  }

  .light {
    --background: 48 100% 98%;
    --foreground: 222 15% 15%;

    --card: 48 100% 96%;
    --card-foreground: 222 15% 15%;

    --popover: 48 100% 96%;
    --popover-foreground: 222 15% 15%;

    --primary: 48 100% 55%;
    --primary-foreground: 48 100% 98%;

    --secondary: 48 20% 90%;
    --secondary-foreground: 222 15% 15%;

    --muted: 48 20% 95%;
    --muted-foreground: 222 15% 45%;

    --accent: 48 30% 85%;
    --accent-foreground: 222 15% 15%;

    --destructive: 0 85% 60%;
    --destructive-foreground: 48 100% 98%;

    --border: 48 20% 88%;
    --input: 48 20% 88%;
    --ring: 48 100% 55%;
    --sidebar-background: 240 5.9% 10%;
    --sidebar-foreground: 240 4.8% 95.9%;
    --sidebar-primary: 224.3 76.3% 48%;
    --sidebar-primary-foreground: 0 0% 100%;
    --sidebar-accent: 240 3.7% 15.9%;
    --sidebar-accent-foreground: 240 4.8% 95.9%;
    --sidebar-border: 240 3.7% 15.9%;
    --sidebar-ring: 217.2 91.2% 59.8%;
  }
}

@layer base {
  * {
    @apply border-border;
  }

  body {
    @apply bg-background text-foreground overflow-x-hidden;
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
  }

  html {
    scroll-behavior: smooth;
  }

  /* Accessibility: consistent gold focus outlines */
  a:focus-visible,
  button:focus-visible,
  [role="button"]:focus-visible,
  input:focus-visible,
  select:focus-visible,
  textarea:focus-visible {
    outline: 2px solid hsl(var(--gold));
    outline-offset: 2px;
  }
}

@layer components {
  .floating-animation {
    animation: none;
  }

  .floating-animation-delayed {
    animation: none;
  }

  .floating-rotation {
    animation: none;
  }

  .gradient-text {
    background: var(--gradient-hologram);
    background-size: 100% 100%;
    animation: none;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .glass-morphism {
    background: linear-gradient(135deg, hsl(var(--card) / 0.9) 0%, hsl(var(--gold) / 0.06) 100%);
    backdrop-filter: blur(8px) saturate(120%);
    border: 1px solid hsl(var(--gold) / 0.18);
    box-shadow: var(--shadow-card);
  }

  .glass-morphism-strong {
    background: linear-gradient(135deg, hsl(var(--card) / 0.92) 0%, hsl(var(--gold) / 0.08) 100%);
    backdrop-filter: blur(10px) saturate(140%);
    border: 1px solid hsl(var(--gold) / 0.22);
    box-shadow: var(--shadow-hologram);
  }

  .tech-glow {
    box-shadow: var(--shadow-neon);
    border: 1px solid hsl(var(--gold) / 0.25);
  }

  .hologram-border {
    position: relative;
    background: hsl(222 16% 8%);
    border: 2px solid transparent;
    background-clip: padding-box;
  }

  .hologram-border::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    margin: -2px;
    border-radius: inherit;
    background: linear-gradient(90deg, hsl(var(--gold)) 0%, hsl(var(--gold-light)) 100%);
    background-size: 100% 100%;
    animation: none;
  }

  .perspective-card {
    transform-style: preserve-3d;
    transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .perspective-card:hover {
    transform: rotateY(8deg) rotateX(8deg) translateZ(30px) scale(1.05);
    box-shadow: var(--shadow-float);
  }

  .data-visualization {
    background: none;
    animation: none;
  }

  .circuit-pattern {
    background: none;
    position: relative;
  }

  .circuit-pattern::before {
    content: '';
    position: absolute;
    inset: 0;
    background: none;
    animation: none;
  }

  .neural-network {
    background: none;
    animation: none;
  }
}

/* Respect user motion preferences */
@media (prefers-reduced-motion: reduce) {
  *:not([data-allow-motion]) {
    animation-duration: 0.001ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.001ms !important;
    scroll-behavior: auto !important;
  }
}

@keyframes float {

  0%,
  100% {
    transform: translateY(0px) rotate(0deg);
  }

  50% {
    transform: translateY(-20px) rotate(2deg);
  }
}

@keyframes float-rotate {
  0% {
    transform: translateY(0px) rotateY(0deg) rotateX(0deg);
  }

  33% {
    transform: translateY(-15px) rotateY(120deg) rotateX(10deg);
  }

  66% {
    transform: translateY(-10px) rotateY(240deg) rotateX(-10deg);
  }

  100% {
    transform: translateY(0px) rotateY(360deg) rotateX(0deg);
  }
}

@keyframes pulse-gold {

  0%,
  100% {
    box-shadow: 0 0 0 0 hsl(var(--gold) / 0.7);
  }

  70% {
    box-shadow: 0 0 0 10px hsl(var(--gold) / 0);
  }
}

@keyframes gradient-shift {

  0%,
  100% {
    background-position: 0% 50%;
  }

  50% {
    background-position: 100% 50%;
  }
}

@keyframes data-flow {
  0% {
    background-position: 0px 0px, 0px 0px;
  }

  100% {
    background-position: 20px 20px, -20px -20px;
  }
}

@keyframes pulse-circuit {

  0%,
  100% {
    opacity: 0.4;
  }

  50% {
    opacity: 0.8;
  }
}

@keyframes neural-pulse {

  0%,
  100% {
    filter: brightness(1) hue-rotate(0deg);
  }

  33% {
    filter: brightness(1.2) hue-rotate(120deg);
  }

  66% {
    filter: brightness(0.8) hue-rotate(240deg);
  }
}

@keyframes matrix-rain {
  0% {
    transform: translateY(-100vh);
    opacity: 1;
  }

  100% {
    transform: translateY(100vh);
    opacity: 0;
  }
}

@keyframes hologram-flicker {

  0%,
  100% {
    opacity: 1;
    filter: brightness(1);
  }

  98% {
    opacity: 1;
    filter: brightness(1);
  }

  99% {
    opacity: 0.8;
    filter: brightness(1.2);
  }

  99.5% {
    opacity: 1;
    filter: brightness(0.8);
  }
}

/* Animation delay utilities */
.animation-delay-1000 {
  animation-delay: 1s;
}

.animation-delay-2000 {
  animation-delay: 2s;
}

.animation-delay-3000 {
  animation-delay: 3s;
}

.animation-delay-4000 {
  animation-delay: 4s;
}